cmake_minimum_required(VERSION 3.27.6)
project(@PROJECT_NAME@-cmake)

set(CMAKE_MODULE_PATH
  "@HERMETIC_FETCHCONTENT_ROOT_DIR@"
  "@HERMETIC_FETCHCONTENT_ROOT_DIR@/modules"
  ${CMAKE_MODULE_PATH}
)

set(HERMETIC_FETCHCONTENT_ROOT_DIR "@HERMETIC_FETCHCONTENT_ROOT_DIR@")

include(hunter_autotools_configure_command)
include(hfc_get_command_in_cleared_env)
include(hfc_resolve_forwarded_flags)

set(HERMETIC_CONFIG_EXTRA_ARGS_STR "@HERMETIC_CONFIG_EXTRA_ARGS@")
separate_arguments(HERMETIC_CONFIG_EXTRA_ARGS NATIVE_COMMAND "${HERMETIC_CONFIG_EXTRA_ARGS_STR}")

set(HERMETIC_CONFIG_LANGUAGE "@HERMETIC_CONFIG_LANGUAGE@")

hfc_resolve_forwarded_flags(
  PROJECT_NAME "@PROJECT_NAME@"
  RESOLVER_ROOT_DIR "${CMAKE_BINARY_DIR}/flags-resolver"
  OUT_RESOLVED_COMPILE_DEFINITIONS_C    resolved_compile_definitions_c
  OUT_RESOLVED_COMPILE_DEFINITIONS_CXX  resolved_compile_definitions_cxx
  OUT_RESOLVED_COMPILE_OPTIONS_C        resolved_compile_options_c
  OUT_RESOLVED_COMPILE_OPTIONS_CXX      resolved_compile_options_cxx
  OUT_RESOLVED_INCLUDE_DIRECTORIES_C    resolved_include_directories_c
  OUT_RESOLVED_INCLUDE_DIRECTORIES_CXX  resolved_include_directories_cxx
  OUT_RESOLVED_LINK_OPTIONS_C           resolved_link_options_c
  OUT_RESOLVED_LINK_OPTIONS_CXX         resolved_link_options_cxx
  OUT_RESOLVED_LINK_DIRECTORIES_C       resolved_link_directories_c
  OUT_RESOLVED_LINK_DIRECTORIES_CXX     resolved_link_directories_cxx
)

# CPPFLAGS and LDFLAGS are single-language slots in ./configure, so the caller
# hints via HERMETIC_CONFIG_LANGUAGE which per-language resolved view to feed.
if(HERMETIC_CONFIG_LANGUAGE STREQUAL "CXX")
  set(resolved_compile_definitions  "${resolved_compile_definitions_cxx}")
  set(resolved_include_directories  "${resolved_include_directories_cxx}")
  set(resolved_link_options         "${resolved_link_options_cxx}")
  set(resolved_link_directories     "${resolved_link_directories_cxx}")
else()
  set(resolved_compile_definitions  "${resolved_compile_definitions_c}")
  set(resolved_include_directories  "${resolved_include_directories_c}")
  set(resolved_link_options         "${resolved_link_options_c}")
  set(resolved_link_directories     "${resolved_link_directories_c}")
endif()

hunter_autotools_configure_command(configure_command_list
  PACKAGE_CONFIGURATION_TYPES @CMAKE_BUILD_TYPE@
  PACKAGE_INSTALL_DIR @PROJECT_INSTALL_PREFIX@
  EXTRA_FLAGS ${HERMETIC_CONFIG_EXTRA_ARGS}
  RESOLVED_COMPILE_DEFINITIONS      ${resolved_compile_definitions}
  RESOLVED_COMPILE_OPTIONS_C        ${resolved_compile_options_c}
  RESOLVED_COMPILE_OPTIONS_CXX      ${resolved_compile_options_cxx}
  RESOLVED_INCLUDE_DIRECTORIES      ${resolved_include_directories}
  RESOLVED_LINK_OPTIONS             ${resolved_link_options}
  RESOLVED_LINK_DIRECTORIES         ${resolved_link_directories}
)

hfc_get_command_in_cleared_env("${configure_command_list}" configure_command)

execute_process(
  COMMAND /bin/bash -c ${configure_command}
  WORKING_DIRECTORY @PROJECT_SOURCE_DIR@/src
  RESULT_VARIABLE CONFIGURE_RESULT
  COMMAND_ECHO STDOUT
)

if(CONFIGURE_RESULT)
  message(FATAL_ERROR "Failed to configure @PROJECT_NAME@-cmake")
endif()
