cmake_minimum_required(VERSION 3.27.6)
# Enable C + CXX so CMAKE_<LANG>_COMPILER_ID is populated — toolchains
# frequently branch on compiler identity inside HERMETIC_TOOLCHAIN_EXTENSION,
# and those conditionals need to resolve the same way the real build does.
project(@PROJECT_NAME@-flags-resolver C CXX)

include("@HERMETIC_FETCHCONTENT_ROOT_DIR@/modules/hfc_genex_eval.cmake")

hfc_genex_eval_capture_dir_properties("@CMAKE_BUILD_TYPE@")
hfc_genex_eval_create_probe_target()
hfc_genex_eval_produce_flag_files("${CMAKE_BINARY_DIR}")
