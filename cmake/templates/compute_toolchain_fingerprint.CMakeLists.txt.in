cmake_minimum_required(VERSION 3.27.0)

# cmake variables forwarded from the parent project - set before project() so
# the toolchain can read them during its execution (mirrors the proxy toolchain behaviour)
@FORWARDED_CMAKE_VARIABLES_CONTENT@

project(hfc_compute_toolchain_fingerprint LANGUAGES @TEMPLATE_ENABLE_LANGUAGES@)

list(APPEND CMAKE_MODULE_PATH "@HERMETIC_FETCHCONTENT_ROOT_DIR@")
list(APPEND CMAKE_MODULE_PATH "@HERMETIC_FETCHCONTENT_ROOT_DIR@/modules")

include(hfc_toolchain_fingerprint)

compute_live_toolchain_fingerprint(hfc_isolated_toolchain_fingerprint)

file(WRITE "@FINGERPRINT_OUTPUT_FILE@" "${hfc_isolated_toolchain_fingerprint}")
